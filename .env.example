# ─── DNA Records — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in the values before running the app.

# ── Application ───────────────────────────────────────────────────────────────

# Full public URL of the deployed app (used for CORS, links, redirects)
# Example: https://dnarecords.yourdomain.com
APP_URL=

# Node environment — use "production" for live deployments
NODE_ENV=production

# Port the Express server listens on (default 5000)
PORT=5000

# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Example: postgres://user:password@host:5432/dna_records
DATABASE_URL=

# ── Session ───────────────────────────────────────────────────────────────────

# Long random string used to sign session cookies — keep this secret!
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# ── Admin Login ───────────────────────────────────────────────────────────────

# Credentials for the admin portal at /admin/login
ADMIN_USERNAME=dnaadmin
ADMIN_PASSWORD=

# ── NIG Command Center Integration ────────────────────────────────────────────

# Division identifier reported to the NIG Command Center
DIVISION_NAME=dnarecords

# Shared secret key — must match the NIG Command Center's NIG_API_KEY
NIG_API_KEY=

# ── AI / OpenAI (optional) ────────────────────────────────────────────────────

# OpenAI API key — required only if AI features are enabled
OPENAI_API_KEY=

# ── Email / Resend (optional) ─────────────────────────────────────────────────

# Resend API key for transactional emails
RESEND_API_KEY=

# ── Replit-only (leave blank on self-hosted deployments) ──────────────────────

# Set automatically by Replit — do not set manually
# REPL_ID=
# ISSUER_URL=
# REPLIT_DOMAINS=
